# === Dependency resolution & locking ===
save-exact=true                  # Installs exact versions (no ^ or ~) – very useful for reproducible templates
package-lock=true                # Always generate package-lock.json (default is true, but explicit is good)

# === Behavior during install ===
ignore-scripts=false             # Allow postinstall scripts (set false in high-security envs)
fund=false                       # Disable funding messages (less noise)

# === Performance & cache ===
prefer-offline=true              # Use cache when possible for faster installs
# cache=~/.npm-cache             # You can customize cache location if needed (rare)

# === Security & strictness ===
strict-ssl=true                  # Keep true unless behind corporate proxy with self-signed certs
audit=true                       # Run security audit on install (recommended)

# === Registry (only change if using private registry) ===
# registry=https://registry.npmjs.org/
# @yourscope:registry=https://your-private-registry.com/